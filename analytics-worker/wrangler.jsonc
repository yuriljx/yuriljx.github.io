{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "jixiao-visitor-analytics",
  "main": "src/index.js",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": false
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jixiao-visitor-analytics",
      "database_id": "0dc4fd67-2568-4cf5-bcbf-2166414bfe67"
    }
  ],
  "triggers": {
    "crons": ["17 3 * * *"]
  }
}
